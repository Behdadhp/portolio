# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Superuser (used by setup.sh)
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=John
ADMIN_LAST_NAME=Doe
ADMIN_BIRTHDATE=1990-01-15

# Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1

# Finnhub
FINNHUB_API_KEY=your-finnhub-api-key-here
FINNHUB_WS_URL=wss://ws.finnhub.io?token={}
FINNHUB_REST_URL=https://finnhub.io/api/v1

# CoinGecko
COINGECKO_MARKETS_URL=https://api.coingecko.com/api/v3/coins/markets

# Email (Gmail SMTP)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=Portfolio Alerts <your-email@gmail.com>
SITE_URL=http://127.0.0.1:8000

# Streaming
BROADCAST_INTERVAL=1
BACKOFF_INITIAL=1
BACKOFF_MAX=60
SYNC_INTERVAL=5
MARKET_CAP_REFRESH=900
